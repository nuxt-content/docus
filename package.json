{
  "name": "assets-standalone",
  "description": "Secure static assets server — assets.alazab.com",
  "version": "1.2.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "nuxt dev docs",
    "dev:docs": "nuxt dev docs",
    "dev:playground": "nuxt dev playground",
    "dev:prepare": "nuxt prepare docs",
    "build": "nuxt build docs",
    "build:docs": "nuxt build docs",
    "build:playground": "nuxt build playground",
    "build:cli": "pnpm --filter create-docus build",
    "generate": "nuxt generate docs",
    "preview": "nuxt preview docs",
    "start": "node docs/.output/server/index.mjs",
    "prepare": "nuxt prepare docs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "release": "release-it",
    "release:layer": "release-it --config .release-it.layer.json",
    "release:cli": "release-it --config .release-it.cli.json",
    "clean": "rimraf **/.nuxt **/.output **/dist **/node_modules/.cache",
    "deploy": "bash deploy.sh"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "@ai-sdk/mcp": "^1.0.36",
    "@ai-sdk/vue": "3.0.168",
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/simple-icons": "^1.2.79",
    "@iconify-json/vscode-icons": "^1.2.45",
    "@nuxt/content": "^3.13.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/ui": "^4.7.1",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/mcp-toolkit": "^0.13.4",
    "@nuxtjs/mdc": "^0.21.1",
    "@nuxtjs/robots": "^6.0.7",
    "@shikijs/core": "^4.0.2",
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@takumi-rs/core": "^1.0.15",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vueuse/core": "^14.2.1",
    "ai": "6.0.168",
    "better-sqlite3": "^12.5.0",
    "defu": "^6.1.7",
    "docus": "workspace:*",
    "exceljs": "^4.4.0",
    "exsolve": "^1.0.8",
    "git-url-parse": "^16.1.0",
    "mammoth": "^1.9.0",
    "motion-v": "^2.2.1",
    "nuxt-llms": "^0.2.0",
    "nuxt-og-image": "^6.4.5",
    "nuxt-studio": "^1.6.0",
    "pdf-lib": "^1.17.1",
    "pkg-types": "^2.3.0",
    "scule": "^1.3.0",
    "shiki-stream": "^0.1.4",
    "tailwindcss": "^4.2.3",
    "ufo": "^1.6.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@nuxt/devtools": "latest",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/eslint-config": "^1.15.2",
    "@release-it/bumper": "^7.0.5",
    "@release-it/conventional-changelog": "^10.0.6",
    "eslint": "^10.2.1",
    "nuxt": "4.4.2",
    "release-it": "^20.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.2.7"
  }
}

